@app.route("/soar")
def soar_page():
    return page_wrap("SOAR Automation", "soar", V5_CSS + """
<div class="v5-hero" style="background:linear-gradient(135deg,#0c1222,#1a1a0d)">
  <div class="v5-hero-icon">⚙️</div>
  <div>
    <div class="v5-hero-title">SOAR Automation Engine</div>
    <div class="v5-hero-sub">IF event → THEN auto-respond &#183; Rule-based orchestration &#183; Incident tracking &#183; Ticketing</div>
  </div>
  <button class="v5-btn-ghost" onclick="fireTest()">🧪 Fire Test Event</button>
</div>
<div class="v5-grid">
  <div class="v5-stat"><div class="v5-stat-val" id="soarRules">--</div><div class="v5-stat-label">Active Rules</div></div>
  <div class="v5-stat"><div class="v5-stat-val" id="soarInc">--</div><div class="v5-stat-label">Total Incidents</div></div>
  <div class="v5-stat"><div class="v5-stat-val" style="color:#ef4444" id="soarCrit">--</div><div class="v5-stat-label">Critical</div></div>
  <div class="v5-stat"><div class="v5-stat-val" style="color:#f97316" id="soarTkts">--</div><div class="v5-stat-label">Open Tickets</div></div>
  <div class="v5-stat"><div class="v5-stat-val" style="color:#22d3ee" id="soarBlocked">--</div><div class="v5-stat-label">Blocked IPs</div></div>
</div>
<div class="v5-content">
  <div class="v5-panel">
    <div class="v5-ph">📋 Automation Rules <button class="v5-btn-ghost v5-btn-sm" onclick="loadRules()">↻</button></div>
    <div id="rulesList"><div class="v5-loading">Loading...</div></div>
  </div>
  <div class="v5-panel">
    <div class="v5-ph">🚨 Recent Incidents <button class="v5-btn-ghost v5-btn-sm" onclick="loadIncidents()">↻</button></div>
    <div id="incList"><div class="v5-loading">Loading...</div></div>
  </div>
  <div class="v5-panel v5-panel-full">
    <div class="v5-ph">🎫 Open Tickets <button class="v5-btn-ghost v5-btn-sm" onclick="loadTickets()">↻</button></div>
    <div id="tktList"><div class="v5-loading">Loading...</div></div>
  </div>
</div>
<script>
function loadStats(){
  fetch('/api/v5/soar/stats').then(function(r){ return r.json(); }).then(function(d){
    document.getElementById('soarRules').textContent=(d.rules_enabled||0)+'/'+(d.rules_total||0);
    document.getElementById('soarInc').textContent=d.total_incidents||0;
    document.getElementById('soarCrit').textContent=d.critical_count||0;
    document.getElementById('soarTkts').textContent=d.open_tickets||0;
    document.getElementById('soarBlocked').textContent=d.blocked_ips||0;
  }).catch(function(e){});
}
function loadRules(){
  fetch('/api/v5/soar/rules').then(function(r){ return r.json(); }).then(function(d){
    var el=document.getElementById('rulesList');
    if(!d.rules||!d.rules.length){el.innerHTML='<div class="v5-empty">No rules loaded.</div>';return;}
    var html='';
    for(var i=0;i<d.rules.length;i++){
      var r=d.rules[i];
      var checked=r.enabled!==false?'checked':'';
      var cls=r.enabled!==false?'v5-rule-on':'v5-rule-off';
      var acts='';
      var actions=r.actions||[];
      for(var j=0;j<actions.length;j++) acts+='<span class="action-tag">'+actions[j]+'</span>';
      html+='<div class="v5-rule '+cls+'">'+
        '<div class="v5-rule-hdr">'+
          '<label class="toggle"><input type="checkbox" '+checked+' onchange="toggleRule(''+r.id+'',this.checked)"><span class="toggle-sl"></span></label>'+
          '<span class="v5-rule-name">'+(r.name||r.id)+'</span>'+
          '<span style="font-size:11px;color:#64748b">P'+(r.priority||1)+'</span>'+
        '</div>'+
        '<div style="font-size:12px;color:#94a3b8;margin-bottom:6px">'+(r.description||'')+'</div>'+
        '<div>'+acts+'</div>'+
      '</div>';
    }
    el.innerHTML=html;
  }).catch(function(e){});
}
function toggleRule(id,enabled){
  fetch('/api/v5/soar/toggle',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({rule_id:id,enabled:enabled})})
  .then(function(){ loadStats(); }).catch(function(e){});
}
function loadIncidents(){
  fetch('/api/v5/soar/incidents?limit=15').then(function(r){ return r.json(); }).then(function(d){
    var el=document.getElementById('incList');
    if(!d.incidents||!d.incidents.length){el.innerHTML='<div class="v5-empty">No incidents yet.</div>';return;}
    var html='';
    for(var i=0;i<d.incidents.length;i++){
      var inc=d.incidents[i];
      html+='<div style="display:flex;align-items:center;gap:8px;padding:8px 0;border-bottom:1px solid var(--border)">'+
        '<span class="sev-pill sev-'+(inc.severity||'INFO')+'">'+(inc.severity||'INFO')+'</span>'+
        '<span style="font-size:13px;flex:1">'+(inc.title||'')+'</span>'+
        '<span style="font-size:11px;color:#64748b">'+((inc.timestamp||'').slice(0,16))+'</span>'+
      '</div>';
    }
    el.innerHTML=html;
  }).catch(function(e){});
}
function loadTickets(){
  fetch('/api/v5/soar/tickets?limit=10').then(function(r){ return r.json(); }).then(function(d){
    var el=document.getElementById('tktList');
    if(!d.tickets||!d.tickets.length){el.innerHTML='<div class="v5-empty">No tickets yet.</div>';return;}
    var rows='';
    for(var i=0;i<d.tickets.length;i++){
      var t=d.tickets[i];
      rows+='<tr>'+
        '<td style="font-size:11px;color:#64748b">'+((t.ticket_id||t.id||'').slice(-8))+'</td>'+
        '<td>'+(t.title||'')+'</td>'+
        '<td><span class="sev-pill sev-'+(t.severity||'MEDIUM')+'">'+(t.severity||'')+'</span></td>'+
        '<td><span class="'+(t.status==='OPEN'?'status-open':'status-closed')+'">'+(t.status||'')+'</span></td>'+
        '<td style="font-size:11px;color:#64748b">'+((t.created_at||t.timestamp||'').slice(0,16))+'</td>'+
      '</tr>';
    }
    el.innerHTML='<table class="v5-table"><thead><tr><th>ID</th><th>Title</th><th>Severity</th><th>Status</th><th>Created</th></tr></thead><tbody>'+rows+'</tbody></table>';
  }).catch(function(e){});
}
function fireTest(){
  fetch('/api/v5/soar/test',{method:'POST'}).then(function(r){ return r.json(); }).then(function(d){
    v5toast(d.success?'&#10003; Test event fired -- check incidents':'&#10007; '+(d.error||'Failed'),d.success?'ok':'error');
    setTimeout(function(){ loadStats(); loadRules(); loadIncidents(); loadTickets(); },1500);
  }).catch(function(e){ v5toast('&#10007; '+e.message,'error'); });
}
loadStats(); loadRules(); loadIncidents(); loadTickets();
</script>
""")

@app.route("/api/v5/soar/stats")
def api_v5_soar_stats():
    if not _se: return jsonify({"rules_enabled":0,"rules_total":0,"total_incidents":0,"open_tickets":0,"critical_count":0,"blocked_ips":0})
    try: return jsonify(_se.get_soar_engine().get_stats())
    except Exception as e: return jsonify({"error":str(e)})

@app.route("/api/v5/soar/rules")
def api_v5_soar_rules():
    if not _se: return jsonify({"rules":[]})
    try: return jsonify({"rules": _se.load_rules()})
    except Exception as e: return jsonify({"rules":[],"error":str(e)})

@app.route("/api/v5/soar/toggle", methods=["POST"])
def api_v5_soar_toggle():
    if not _se: return jsonify({"success":False})
    try:
        rule_id = (request.json or {}).get("rule_id","")
        enabled = (request.json or {}).get("enabled", True)
        _se.enable_rule(rule_id, enabled)
        return jsonify({"success":True})
    except Exception as e: return jsonify({"success":False,"error":str(e)})

@app.route("/api/v5/soar/incidents")
def api_v5_soar_incidents():
    if not _se: return jsonify({"incidents":[]})
    try:
        limit = int(request.args.get("limit",50))
        return jsonify({"incidents": _se.get_soar_engine().get_incidents(limit)})
    except Exception as e: return jsonify({"incidents":[],"error":str(e)})

@app.route("/api/v5/soar/tickets")
def api_v5_soar_tickets():
    if not _se: return jsonify({"tickets":[]})
    try:
        limit = int(request.args.get("limit",20))
        return jsonify({"tickets": _se.get_soar_engine().get_tickets(limit)})
    except Exception as e: return jsonify({"tickets":[],"error":str(e)})

@app.route("/api/v5/soar/test", methods=["POST"])
def api_v5_soar_test():
    if not _se: return jsonify({"success":False,"error":"soar_engine not installed"})
    try:
        _se.get_soar_engine().process_event({
            "trigger":"credential_exposure","type":"credential_exposure",
            "severity":"CRITICAL","title":"[TEST] Credentials found in stealer log",
            "domain":"testcorp.com","source":"VoraGuard Test"
        })
        return jsonify({"success":True})
    except Exception as e: return jsonify({"success":False,"error":str(e)})

