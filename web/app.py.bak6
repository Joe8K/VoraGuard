@app.route("/darkweb")
def darkweb_page():
    return page_wrap("Dark Web Monitor", "darkweb", V5_CSS + """
<div class="v5-hero" style="background:linear-gradient(135deg,#0c1222,#1a0d2e)">
  <div class="v5-hero-icon">🕵️</div>
  <div>
    <div class="v5-hero-title">Dark Web & Stealer Log Monitor</div>
    <div class="v5-hero-sub">LeakIX &#183; Have I Been Pwned &#183; Paste sites &#183; Telegram &#183; Stealer log tracking</div>
  </div>
</div>
<div class="v5-grid">
  <div class="v5-stat"><div class="v5-stat-val" id="dwTotal">--</div><div class="v5-stat-label">Total Findings</div></div>
  <div class="v5-stat"><div class="v5-stat-val" style="color:#ef4444" id="dwCrit">--</div><div class="v5-stat-label">Critical</div></div>
  <div class="v5-stat"><div class="v5-stat-val" style="color:#f97316" id="dwCreds">--</div><div class="v5-stat-label">Credential Leaks</div></div>
  <div class="v5-stat"><div class="v5-stat-val" style="color:#22d3ee" id="dwSrcs">--</div><div class="v5-stat-label">Sources Checked</div></div>
</div>
<div class="v5-content">
  <div class="v5-panel v5-panel-full">
    <div class="v5-ph">🔍 Dark Web Scan</div>
    <div class="v5-row" style="margin-bottom:12px">
      <div style="flex:1"><label style="font-size:11px;color:var(--muted);display:block;margin-bottom:4px">Target Domain</label>
        <input type="text" id="dwDomain" class="v5-input" placeholder="yourcompany.com"></div>
      <div style="flex:1"><label style="font-size:11px;color:var(--muted);display:block;margin-bottom:4px">Email (optional)</label>
        <input type="text" id="dwEmail" class="v5-input" placeholder="admin@yourcompany.com"></div>
      <button class="v5-btn" style="white-space:nowrap;align-self:flex-end" onclick="runDwScan()">🔍 Scan</button>
    </div>
    <div id="dwResult"></div>
  </div>
  <div class="v5-panel v5-panel-full">
    <div class="v5-ph">📋 All Findings <button class="v5-btn-ghost v5-btn-sm" onclick="loadDwFindings()">↻</button></div>
    <div id="dwFindings"><div class="v5-loading">Loading...</div></div>
  </div>
</div>
<script>
function loadDwStats(){
  fetch('/api/v5/darkweb/stats').then(function(r){ return r.json(); }).then(function(d){
    document.getElementById('dwTotal').textContent=d.total_findings||0;
    document.getElementById('dwCrit').textContent=d.critical||d.critical_count||0;
    document.getElementById('dwCreds').textContent=d.credential_leaks||0;
    document.getElementById('dwSrcs').textContent=d.sources_checked||0;
  }).catch(function(e){});
}
function loadDwFindings(){
  fetch('/api/v5/darkweb/findings?limit=30').then(function(r){ return r.json(); }).then(function(d){
    var el=document.getElementById('dwFindings');
    var f=d.findings||[];
    if(!f.length){el.innerHTML='<div class="v5-empty">No findings yet. Run a scan first.</div>';return;}
    var html='';
    for(var i=0;i<f.length;i++){
      var x=f[i];
      var sev=x.severity||'MEDIUM';
      html+='<div class="v5-card sev-bd-'+sev+'">'+
        '<div class="v5-card-hdr">'+
          '<span class="sev-pill sev-'+sev+'">'+sev+'</span>'+
          '<span class="v5-card-title">'+(x.title||x.type||'Finding')+'</span>'+
          '<span class="v5-card-muted">'+(x.source||'')+'</span>'+
          '<span class="v5-card-muted">'+((x.date||x.timestamp||'').slice(0,10))+'</span>'+
        '</div>'+
        '<div class="v5-card-body">'+(x.summary||x.description||'')+'</div>'+
      '</div>';
    }
    el.innerHTML=html;
  }).catch(function(e){ document.getElementById('dwFindings').innerHTML='<div class="v5-error">'+e.message+'</div>'; });
}
function runDwScan(){
  var domain=document.getElementById('dwDomain').value.trim();
  var email=document.getElementById('dwEmail').value.trim();
  if(!domain){v5toast('Enter a domain','error');return;}
  var el=document.getElementById('dwResult');
  el.innerHTML='<div class="v5-loading">&#128269; Scanning dark web sources -- this may take 30-60 seconds...</div>';
  fetch('/api/v5/darkweb/scan',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({domain:domain,email:email})})
  .then(function(r){ return r.json(); })
  .then(function(d){
    var f=d.findings||[];
    var html='<div style="background:rgba(34,211,238,0.06);padding:10px 14px;border-radius:8px;margin-bottom:12px;font-size:13px">'+
      'Scan complete: <b>'+f.length+' findings</b> from '+(d.sources_checked||0)+' sources.</div>';
    for(var i=0;i<f.length;i++){
      var x=f[i];
      var sev=x.severity||'MEDIUM';
      html+='<div class="v5-card sev-bd-'+sev+'">'+
        '<div class="v5-card-hdr">'+
          '<span class="sev-pill sev-'+sev+'">'+sev+'</span>'+
          '<span class="v5-card-title">'+(x.title||x.type||'')+'</span>'+
          '<span class="v5-card-muted">'+(x.source||'')+'</span>'+
        '</div>'+
        '<div class="v5-card-body">'+(x.summary||x.description||'')+'</div>'+
      '</div>';
    }
    el.innerHTML=html;
    loadDwStats(); loadDwFindings();
  }).catch(function(e){ el.innerHTML='<div class="v5-error">Error: '+e.message+'</div>'; });
}
loadDwStats(); loadDwFindings();
</script>
""")

@app.route("/api/v5/darkweb/stats")
def api_v5_dw_stats():
    if not _dw: return jsonify({"total_findings":0,"critical":0,"credential_leaks":0,"sources_checked":0})
    try:
        findings = _dw.get_all_findings(200)
        return jsonify({
            "total_findings":  len(findings),
            "critical":        sum(1 for f in findings if f.get("severity")=="CRITICAL"),
            "credential_leaks":sum(1 for f in findings if "credential" in f.get("type","").lower() or "password" in f.get("title","").lower()),
            "sources_checked": len(set(f.get("source","") for f in findings)),
        })
    except Exception as e:
        return jsonify({"total_findings":0,"error":str(e)})

@app.route("/api/v5/darkweb/findings")
def api_v5_dw_findings():
    if not _dw: return jsonify({"findings":[]})
    try:
        limit    = int(request.args.get("limit",50))
        findings = _dw.get_all_findings(limit)
        return jsonify({"findings": findings})
    except Exception as e:
        return jsonify({"findings":[],"error":str(e)})

@app.route("/api/v5/darkweb/scan", methods=["POST"])
def api_v5_dw_scan():
    if not _dw: return jsonify({"findings":[],"error":"darkweb_monitor not installed","sources_checked":0})
    try:
        domain = (request.json or {}).get("domain","")
        email  = (request.json or {}).get("email","")
        if not domain: return jsonify({"error":"domain required"})
        result = _dw.full_darkweb_scan(domain)
        return jsonify(result)
    except Exception as e:
        return jsonify({"findings":[],"sources_checked":0,"error":str(e)})

