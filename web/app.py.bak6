@app.route("/api/v5/network/pipeline/status")
def api_v5_network_pipeline_status():
    try:
        from scanner.network_ids import get_ids_engine
        engine = get_ids_engine()
        if engine:
            return jsonify({
                "running": engine.running,
                "alerts": len(engine.alerts),
                "packets": engine.packet_count,
                "blocked": len(getattr(engine, "blocked_ips", [])),
                "interface": engine.interface
            })
        return jsonify({"running": False, "alerts": 0, "packets": 0, "blocked": 0, "interface": "eth0"})
    except Exception as e:
        return jsonify({"running": False, "alerts": 0, "packets": 0, "blocked": 0, "error": str(e)})

