@app.route("/advanced")
def advanced_page():
    return page_wrap("Advanced Intel", "advanced", V5_CSS + """
<div class="v5-hero" style="background:linear-gradient(135deg,#0c1222,#0d1a20)">
  <div class="v5-hero-icon">&#128300;</div>
  <div>
    <div class="v5-hero-title">Advanced Intelligence</div>
    <div class="v5-hero-sub">Attacker ROI &#183; Business Impact &#183; OWASP Top 10 &#183; GRC Report &#183; Supply Chain &#183; Honey Trap</div>
  </div>
</div>
<div class="v5-content">
  <div class="v5-panel v5-panel-full">
    <div class="v5-ph">&#128300; Run Advanced Analysis</div>
    <div style="display:flex;gap:10px;margin-bottom:14px">
      <input type="text" id="advDomain" class="v5-input" placeholder="Domain to analyse e.g. example.com" style="flex:1">
      <button class="v5-btn" onclick="runAdvanced()">Analyse</button>
    </div>
    <div style="font-size:11px;color:#64748b;margin-bottom:10px">
      Runs: Attacker ROI Score &#183; CIA Triad Impact &#183; OWASP Top 10 &#183; GRC Compliance &#183; Attack Surface Delta &#183; Honey Trap &#183; Threat Actor Correlation &#183; Supply Chain
    </div>
    <div id="advResult"></div>
  </div>
</div>
<script>
function runAdvanced(){
  var domain=document.getElementById('advDomain').value.trim();
  if(!domain){alert('Enter a domain');return;}
  var el=document.getElementById('advResult');
  el.innerHTML='<div class="v5-loading">Running advanced intelligence modules...</div>';
  fetch('/api/v5/advanced/full',{method:'POST',headers:{'Content-Type':'application/json'},
    body:JSON.stringify({domain:domain,nmap_result:{},ssl_info:{},dns_health:{},vuln_analysis:{},dnstwist_result:{},harvester_result:{},risk_score:{},vt_result:{}})})
    .then(function(r){return r.json();})
    .then(function(d){
      if(d.error){el.innerHTML='<div class="v5-error">'+d.error+'</div>';return;}
      var html='';
      var roi=d.roi||{};
      if(roi.total_roi_score!==undefined){
        var rc=roi.total_roi_score>=75?'#ef4444':roi.total_roi_score>=55?'#fb923c':roi.total_roi_score>=35?'#fbbf24':'#34d399';
        html+='<div class="v5-card" style="margin-bottom:10px">'
          +'<div class="v5-ph">&#127919; Attacker ROI Score</div>'
          +'<div style="display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:10px;text-align:center;margin-bottom:10px">'
          +'<div><div style="font-size:2rem;font-weight:800;color:'+rc+'">'+roi.total_roi_score+'</div><div style="font-size:11px;color:#64748b">Total ROI</div></div>'
          +'<div><div style="font-size:1.5rem;font-weight:700;color:#fb923c">'+roi.ease_score+'</div><div style="font-size:11px;color:#64748b">Ease of Exploit</div></div>'
          +'<div><div style="font-size:1.5rem;font-weight:700;color:#38bdf8">'+roi.value_score+'</div><div style="font-size:11px;color:#64748b">Data Value</div></div>'
          +'<div><div style="font-size:1.5rem;font-weight:700;color:#a78bfa">'+roi.stealth_score+'</div><div style="font-size:11px;color:#64748b">Stealth Factor</div></div>'
          +'</div>'
          +'<div style="font-size:12px;color:'+rc+';font-weight:700;margin-bottom:6px">'+roi.roi_label+'</div>'
          +'<div style="font-size:11px;color:#94a3b8">'+roi.attacker_type+'</div>'
          +'</div>';
      }
      var ht=d.honeytrap||{};
      if(ht.verdict){
        var htc=ht.verdict==='LIKELY HONEYPOT'?'#ef4444':ht.verdict==='POSSIBLE HONEYPOT'?'#fbbf24':'#34d399';
        html+='<div class="v5-card" style="margin-bottom:10px">'
          +'<div class="v5-ph">&#127855; Honey Trap Detection</div>'
          +'<div style="font-size:14px;font-weight:700;color:'+htc+'">'+ht.verdict+' ('+ht.confidence_pct+'% confidence)</div>'
          +'<div style="font-size:12px;color:#94a3b8;margin-top:6px">'+ht.recommendation+'</div>'
          +'</div>';
      }
      var sc=d.supply_chain||{};
      if(sc.components_detected!==undefined){
        html+='<div class="v5-card" style="margin-bottom:10px">'
          +'<div class="v5-ph">&#128279; Supply Chain</div>'
          +'<div style="font-size:12px;color:#94a3b8;margin-bottom:8px">'+sc.components_detected+' components detected &nbsp;|&nbsp; Risk: <span style="color:'+(sc.supply_chain_risk==="CRITICAL"?'#ef4444':sc.supply_chain_risk==="HIGH"?'#fb923c':'#fbbf24')+'">'+sc.supply_chain_risk+'</span></div>'
          +(sc.components||[]).slice(0,5).map(function(c){
            return '<div style="padding:4px 0;border-bottom:1px solid #1e2d40;font-size:12px;display:flex;justify-content:space-between"><span style="color:#e8f0fe">'+c.technology+'</span><span style="color:#94a3b8">'+c.note+'</span></div>';
          }).join('')
          +'</div>';
      }
      var owasp=d.owasp||{};
      if(owasp.findings){
        html+='<div class="v5-card" style="margin-bottom:10px">'
          +'<div class="v5-ph">&#128272; OWASP Top 10</div>'
          +'<div style="font-size:12px;color:#94a3b8;margin-bottom:8px">'+owasp.triggered_count+' of 10 categories triggered</div>'
          +(owasp.findings||[]).map(function(f){
            return '<div style="padding:6px 0;border-bottom:1px solid #1e2d40">'
              +'<div style="font-size:12px;font-weight:700;color:'+(f.severity==="HIGH"?'#f87171':'#fbbf24')+'">'+f.id+' — '+f.name+'</div>'
              +'<div style="font-size:11px;color:#94a3b8">'+f.remediation+'</div>'
              +'</div>';
          }).join('')
          +'</div>';
      }
      var grc=d.grc||{};
      if(grc.priority_actions){
        html+='<div class="v5-card" style="margin-bottom:10px">'
          +'<div class="v5-ph">&#128203; GRC Priority Actions</div>'
          +(grc.priority_actions||[]).map(function(a){
            return '<div style="padding:6px 0;border-bottom:1px solid #1e2d40;display:flex;gap:8px;align-items:flex-start">'
              +'<span style="background:'+(a.priority==="P1"?'rgba(239,68,68,0.2)':'rgba(251,146,60,0.2)')+';color:'+(a.priority==="P1"?'#ef4444':'#fb923c')+';padding:2px 6px;border-radius:3px;font-size:10px;font-weight:700;flex-shrink:0">'+a.priority+'</span>'
              +'<div><div style="font-size:12px;color:#e8f0fe">'+a.action+'</div><div style="font-size:11px;color:#64748b">Owner: '+a.owner+'</div></div>'
              +'</div>';
          }).join('')
          +'</div>';
      }
      var ac=d.actor_corr||{};
      if(ac.actors&&ac.actors.length){
        html+='<div class="v5-card">'
          +'<div class="v5-ph">&#127822; Threat Actor Correlation</div>'
          +'<div style="font-size:12px;color:#94a3b8;margin-bottom:8px">'+ac.matched_actor_count+' actor(s) correlated &nbsp;|&nbsp; Overall threat: <span style="color:#ef4444">'+ac.overall_threat+'</span></div>'
          +(ac.actors||[]).map(function(a){
            return '<div style="padding:6px 0;border-bottom:1px solid #1e2d40">'
              +'<div style="font-size:12px;font-weight:700;color:#e8f0fe">'+a.group+' <span style="color:#64748b">('+a.nation_state+')</span></div>'
              +'<div style="font-size:11px;color:#94a3b8">Score: '+a.correlation_score+' &nbsp;|&nbsp; '+a.motivation+'</div>'
              +'</div>';
          }).join('')
          +'</div>';
      }
      el.innerHTML=html||'<div class="v5-empty">Run a domain scan first to get full advanced analysis results.</div>';
    }).catch(function(e){el.innerHTML='<div class="v5-error">'+e.message+'</div>';});
}
</script>
""")

