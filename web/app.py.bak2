""" + "".join(f"""      <div class="vg-col" style="min-width:180px">
        <div style="background:var(--bg4);border-radius:10px;padding:14px 16px">
          <div style="font-size:13px;font-weight:700;color:var(--cyan);margin-bottom:4px">{name}</div>
