    }
    document.getElementById('test-result').innerHTML = html;
  } catch(e) {
    document.getElementById('test-result').innerHTML = '<span style="color:var(--red)">Error: '+e.message+'</span>';
  }
  btn.disabled = false;
  document.getElementById('test-btn-inner').textContent = '🔔 Send Test Alert';
}
document.addEventListener('DOMContentLoaded', loadChannelStatus);
</script>
