# EPSS VULNERABILITY INTELLIGENCE
# ─────────────────────────────────────────────────────────────────────────────

@app.route("/epss")
def epss_page():
    return page_wrap("EPSS Intel", "epss", V5_CSS + """
<div class="v5-hero" style="background:linear-gradient(135deg,#0c1222,#0d1a20)">
  <div class="v5-hero-icon">🛡️</div>
  <div>
    <div class="v5-hero-title">Vulnerability & Exploit Intelligence</div>
    <div class="v5-hero-sub">EPSS exploit probability · CVSS scoring · CISA KEV · True CVE prioritization</div>
  </div>
</div>
<div class="v5-content">
  <div class="v5-panel">
    <div class="v5-ph">🔍 CVE Lookup</div>
    <div class="v5-form">
      <input type="text" id="cveInput" class="v5-input" placeholder="CVE-2024-12345">
      <button class="v5-btn" onclick="lookupCVE()">Look Up</button>
      <div id="cveResult"></div>
    </div>
    <div class="v5-ph" style="margin-top:20px">📋 Prioritize Multiple CVEs</div>
    <div class="v5-form">
      <textarea id="cveList" class="v5-input" rows="6" placeholder="CVE-2024-1234&#10;CVE-2023-5678&#10;CVE-2024-9999"></textarea>
      <button class="v5-btn" onclick="prioritizeCVEs()">Prioritize List</button>
      <div id="prioResult"></div>
    </div>
  </div>
  <div class="v5-panel">
    <div class="v5-ph">🔥 Top Risky CVEs Today</div>
    <div id="topRisky"><div class="v5-loading">Loading...</div></div>
  </div>
</div>
<script>
function lookupCVE(){
  var cve=(document.getElementById('cveInput')||{}).value.trim();
  if(!cve){alert('Enter a CVE ID'); return;}
  var el=document.getElementById('cveResult');
  if(el) el.innerHTML='<div style="color:#94a3b8">Looking up '+cve+'...</div>';
  fetch('/api/v5/epss/score?cve='+encodeURIComponent(cve)).then(function(r){return r.json();}).then(function(d){
    if(!el) return;
    if(d.error){el.innerHTML='<div style="color:#f87171">Error: '+d.error+'</div>';return;}
    var pct=Math.round((d.epss||0)*10000)/100;
    var riskColor={CRITICAL:'#f87171',HIGH:'#fb923c',MEDIUM:'#fbbf24',LOW:'#34d399',UNKNOWN:'#94a3b8'};
    var rc=riskColor[d.risk]||'#94a3b8';
    el.innerHTML='<div class="v5-card" style="border-left:3px solid '+rc+'">'
      +'<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px">'
      +'<span style="font-size:18px;font-weight:800;color:#e8f0fe;font-family:monospace">'+d.cve+'</span>'
      +'<span class="v5-badge" style="background:'+rc+'22;color:'+rc+';font-size:13px;padding:4px 12px">'+d.risk+'</span></div>'
      +'<div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;text-align:center">'
      +'<div><div style="font-size:2.5rem;font-weight:800;color:'+rc+'">'+pct+'%</div><div style="color:#94a3b8;font-size:12px">Exploit Probability</div></div>'
      +'<div><div style="font-size:2.5rem;font-weight:800;color:#38bdf8">'+Math.round((d.percentile||0)*100)+'th</div><div style="color:#94a3b8;font-size:12px">Percentile</div></div>'
      +'<div><div style="font-size:1.2rem;font-weight:700;color:#94a3b8">'+d.date+'</div><div style="color:#94a3b8;font-size:12px">EPSS Date</div></div>'
      +'</div>'
      +'<div style="margin-top:12px;padding-top:12px;border-top:1px solid #1e2d40;font-size:11px;color:#64748b">Source: '+d.source+'</div>'
      +'</div>';
  }).catch(function(e){if(el) el.innerHTML='<div style="color:#f87171">Lookup failed</div>';});
}
function prioritizeCVEs(){
  var raw=(document.getElementById('cveBulk')||{}).value||'';
  var cves=raw.split(/[
,\s]+/).map(function(c){return c.trim().toUpperCase();}).filter(function(c){return c.indexOf('CVE-')===0;});
  if(!cves.length){alert('Enter CVE IDs (one per line)'); return;}
  var el=document.getElementById('priorityResult');
  if(el) el.innerHTML='<div style="color:#94a3b8">Enriching '+cves.length+' CVEs...</div>';
  fetch('/api/v5/epss/enrich',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({cves:cves})}).then(function(r){return r.json();}).then(function(d){
    var results=d.results||[];
    if(!el) return;
    if(!results.length){el.innerHTML='<div style="color:#94a3b8">No results</div>';return;}
    var riskColor={CRITICAL:'#f87171',HIGH:'#fb923c',MEDIUM:'#fbbf24',LOW:'#34d399',UNKNOWN:'#94a3b8'};
    var html='<table style="width:100%;border-collapse:collapse;font-size:12px">'
      +'<thead><tr style="background:#0f1829">'
      +'<th style="padding:8px;text-align:left;color:#94a3b8">CVE</th>'
      +'<th style="padding:8px;text-align:center;color:#94a3b8">EPSS</th>'
      +'<th style="padding:8px;text-align:center;color:#94a3b8">Risk</th>'
      +'<th style="padding:8px;text-align:center;color:#94a3b8">KEV</th>'
      +'<th style="padding:8px;text-align:left;color:#94a3b8">Ransomware</th>'
      +'</tr></thead><tbody>';
    for(var i=0;i<results.length;i++){
      var r=results[i];
      var rc=riskColor[r.risk]||'#94a3b8';
      var pct=Math.round((r.epss||0)*10000)/100;
      html+='<tr style="border-bottom:1px solid #1e2d40">'
        +'<td style="padding:8px;font-family:monospace;color:#38bdf8">'+r.cve+'</td>'
        +'<td style="padding:8px;text-align:center;font-weight:700;color:'+rc+'">'+pct+'%</td>'
        +'<td style="padding:8px;text-align:center"><span style="background:'+rc+'22;color:'+rc+';padding:2px 8px;border-radius:4px;font-size:10px">'+r.risk+'</span></td>'
        +'<td style="padding:8px;text-align:center">'+(r.in_kev?'<span style="color:#f87171;font-weight:700">YES</span>':'<span style="color:#34d399">No</span>')+'</td>'
        +'<td style="padding:8px;color:#94a3b8;font-size:11px">'+((r.ransomware&&r.ransomware!='Unknown')?r.ransomware:'')+'</td>'
        +'</tr>';
    }
    el.innerHTML=html+'</tbody></table>';
  }).catch(function(e){if(el) el.innerHTML='<div style="color:#f87171">Failed</div>';});
}
function loadTop(){
  var el=document.getElementById('topCVEs');
  if(el) el.innerHTML='<div style="color:#94a3b8">Loading live EPSS data from FIRST.org...</div>';
  fetch('/api/v5/epss/top?limit=20').then(function(r){return r.json();}).then(function(d){
    var cves=d.cves||[];
    if(!el) return;
    if(!cves.length){el.innerHTML='<div style="color:#94a3b8">No data</div>';return;}
    var riskColor={CRITICAL:'#f87171',HIGH:'#fb923c',MEDIUM:'#fbbf24',LOW:'#34d399'};
    var html='<div style="font-size:11px;color:#64748b;margin-bottom:8px">Source: '+d.source+' &bull; Updated: '+new Date().toLocaleDateString()+'</div>'
      +'<table style="width:100%;border-collapse:collapse;font-size:12px">'
      +'<thead><tr style="background:#0f1829">'
      +'<th style="padding:8px;color:#94a3b8">#</th>'
      +'<th style="padding:8px;color:#94a3b8">CVE</th>'
      +'<th style="padding:8px;text-align:center;color:#94a3b8">EPSS %</th>'
      +'<th style="padding:8px;text-align:center;color:#94a3b8">Percentile</th>'
      +'<th style="padding:8px;text-align:center;color:#94a3b8">Risk</th>'
      +'</tr></thead><tbody>';
    for(var i=0;i<cves.length;i++){
      var c=cves[i];
      var rc=riskColor[c.risk]||'#94a3b8';
      var pct=Math.round((c.epss||0)*10000)/100;
      html+='<tr style="border-bottom:1px solid #1e2d40">'
        +'<td style="padding:8px;color:#64748b">'+(i+1)+'</td>'
        +'<td style="padding:8px;font-family:monospace"><a href="https://nvd.nist.gov/vuln/detail/'+c.cve+'" target="_blank" style="color:#38bdf8;text-decoration:none">'+c.cve+'</a></td>'
        +'<td style="padding:8px;text-align:center;font-weight:700;color:'+rc+'">'+pct+'%</td>'
        +'<td style="padding:8px;text-align:center;color:#94a3b8">'+Math.round((c.percentile||0)*100)+'th</td>'
        +'<td style="padding:8px;text-align:center"><span style="background:'+rc+'22;color:'+rc+';padding:2px 8px;border-radius:4px;font-size:10px;font-weight:700">'+c.risk+'</span></td>'
        +'</tr>';
    }
    el.innerHTML=html+'</tbody></table>';
  }).catch(function(e){if(el) el.innerHTML='<div style="color:#f87171">Failed to load: '+e+'</div>';});
}
function loadKEV(){
  var el=document.getElementById('kevList');
  if(el) el.innerHTML='<div style="color:#94a3b8">Loading CISA KEV...</div>';
  fetch('/api/v5/epss/kev').then(function(r){return r.json();}).then(function(d){
    var kev=d.kev||[];
    if(!el||!kev.length){if(el)el.innerHTML='<div style="color:#94a3b8">No KEV data</div>';return;}
    var html='<div style="font-size:11px;color:#64748b;margin-bottom:8px">CISA Known Exploited Vulnerabilities: '+kev.length+' entries</div>'
      +'<table style="width:100%;border-collapse:collapse;font-size:12px">'
      +'<thead><tr style="background:#0f1829">'
      +'<th style="padding:8px;color:#94a3b8">CVE</th>'
      +'<th style="padding:8px;color:#94a3b8">Vulnerability</th>'
      +'<th style="padding:8px;color:#94a3b8">Vendor</th>'
      +'<th style="padding:8px;text-align:center;color:#94a3b8">Due Date</th>'
      +'<th style="padding:8px;text-align:center;color:#94a3b8">Ransomware</th>'
      +'</tr></thead><tbody>';
    for(var i=0;i<kev.length;i++){
      var k=kev[i];
      var isRansom=k.knownRansomwareCampaignUse&&k.knownRansomwareCampaignUse!='Unknown';
      var overdue=new Date(k.dueDate)<new Date();
      html+='<tr style="border-bottom:1px solid #1e2d40">'
        +'<td style="padding:8px;font-family:monospace"><a href="https://nvd.nist.gov/vuln/detail/'+k.cveID+'" target="_blank" style="color:#38bdf8;text-decoration:none">'+k.cveID+'</a></td>'
        +'<td style="padding:8px;color:#e8f0fe">'+String(k.vulnerabilityName||'').substring(0,55)+'</td>'
        +'<td style="padding:8px;color:#94a3b8">'+String(k.vendorProject||'').substring(0,20)+'</td>'
        +'<td style="padding:8px;text-align:center;color:'+(overdue?'#f87171':'#34d399')+'">'+k.dueDate+'</td>'
        +'<td style="padding:8px;text-align:center">'+(isRansom?'<span style="color:#f87171;font-weight:700">YES</span>':'<span style="color:#64748b">No</span>')+'</td>'
        +'</tr>';
    }
    el.innerHTML=html+'</tbody></table>';
  }).catch(function(e){if(el) el.innerHTML='<div style="color:#f87171">Failed</div>';});
}
document.addEventListener('DOMContentLoaded',function(){loadTop();});
</script>
""")

@app.route("/api/v5/epss/score")
def api_v5_epss_score():
    if not _ei: return jsonify({"error":"epss_intel not installed"})
    cve = request.args.get("cve","").upper()
    if not cve: return jsonify({"error":"cve required"})
    try: return jsonify(_ei.get_epss_score(cve))
    except Exception as e: return jsonify({"error":str(e)})

@app.route("/api/v5/epss/prioritize", methods=["POST"])
def api_v5_epss_prioritize():
    if not _ei: return jsonify({"prioritized":[],"error":"epss_intel not installed"})
    try:
        cves = (request.json or {}).get("cves",[])
        if not cves: return jsonify({"error":"cves required"})
        bulk = _ei.get_epss_bulk(cves)
        result = []
        for cve in cves:
            data = bulk.get(cve.upper(),{})
            scored = _ei.compute_priority_score(cve.upper(), data.get("cvss_score",0), data.get("kev",False))
            result.append(scored)
        result.sort(key=lambda x: x.get("vorascore",x.get("priority_score",0)), reverse=True)
        return jsonify({"prioritized": result})
    except Exception as e: return jsonify({"prioritized":[],"error":str(e)})

@app.route("/api/v5/epss/top")
def api_v5_epss_top():
    try:
        from scanner.epss_intel import get_top_epss
        limit = int(request.args.get('limit', 20))
        return jsonify({'cves': get_top_epss(limit), 'source': 'FIRST.org EPSS API'})
    except Exception as e:
        return jsonify({'cves': [], 'error': str(e)})
@app.route("/executive")
def executive_page():
    return page_wrap("Executive", "executive", V5_CSS + """
<style>
.exec-ring{display:flex;flex-direction:column;align-items:center;justify-content:center;
  width:160px;height:160px;border-radius:50%;border:6px solid #22c55e;margin:0 auto 16px;}
.exec-score{font-size:48px;font-weight:900;}
.exec-lvl{font-size:13px;font-weight:700;letter-spacing:1px;}
.exec-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:14px;padding:16px 24px 24px;}
.exec-card{background:#0c1222;border:1px solid var(--border);border-radius:14px;padding:20px;}
.exec-card-title{font-size:12px;color:#64748b;font-weight:700;margin-bottom:12px;text-transform:uppercase;letter-spacing:0.5px;}
.exec-row{display:flex;justify-content:space-between;align-items:center;padding:6px 0;border-bottom:1px solid rgba(148,163,184,0.06);}
.exec-val{font-size:20px;font-weight:800;}
.pwa-btn{position:fixed;bottom:20px;right:20px;background:#22d3ee;color:#080d1a;padding:12px 20px;border-radius:999px;font-weight:700;cursor:pointer;box-shadow:0 4px 24px rgba(34,211,238,0.4);border:none;font-size:13px;}
</style>
<link rel="manifest" href="/manifest.json">
<div style="text-align:center;padding:28px 24px 8px">
  <div style="font-size:12px;color:#64748b;margin-bottom:12px;letter-spacing:1px">OVERALL ORGANISATION RISK</div>
  <div id="riskRing" class="exec-ring">
    <div id="riskScore" class="exec-score">—</div>
    <div id="riskLvl" class="exec-lvl">LOADING</div>
  </div>
  <div style="font-size:12px;color:#64748b">Updated: <span id="updatedAt">—</span></div>
</div>
<div class="exec-grid" id="execGrid">
  <div class="exec-card"><div class="exec-card-title">📡 Network Monitor</div><div id="xNet"><div class="v5-loading">Loading...</div></div></div>
  <div class="exec-card"><div class="exec-card-title">🕵️ Dark Web Exposure</div><div id="xDw"><div class="v5-loading">Loading...</div></div></div>
  <div class="exec-card"><div class="exec-card-title">⚙️ SOAR Automation</div><div id="xSoar"><div class="v5-loading">Loading...</div></div></div>
  <div class="exec-card"><div class="exec-card-title">🛡️ Top CVEs</div><div id="xCve"><div class="v5-loading">Loading...</div></div></div>
  <div class="exec-card"><div class="exec-card-title">🎭 Threat Actors</div><div id="xActors"><div class="v5-loading">Loading...</div></div></div>
</div>
<button class="pwa-btn" id="installBtn" style="display:none" onclick="installPWA()">📱 Install App</button>
<script>
let deferredPrompt;
window.addEventListener('beforeinstallprompt',e=>{e.preventDefault();deferredPrompt=e;document.getElementById('installBtn').style.display='block';});
function installPWA(){if(deferredPrompt){deferredPrompt.prompt();deferredPrompt=null;document.getElementById('installBtn').style.display='none';}}
const riskCol={CRITICAL:'#ef4444',HIGH:'#f97316',MEDIUM:'#f59e0b',LOW:'#22c55e'};
function metric(label,val,col){return `<div class="exec-row"><span style="font-size:13px">${label}</span><span class="exec-val" ${col?`style="color:${col}"`:''}>${val}</span></div>`;}
async function loadExec(){
  try{
    // Network
    const ns=await fetch('/api/v5/network/status').then(r=>r.json()).catch(()=>({}));
    const na=await fetch('/api/v5/network/alerts?limit=50').then(r=>r.json()).catch(()=>({alerts:[]}));
    const crits=(na.alerts||[]).filter(a=>a.severity==='CRITICAL').length;
    document.getElementById('xNet').innerHTML=
      metric('Status',ns.running?'Running':'Stopped',ns.running?'#22c55e':'#ef4444')+
      metric('Packets',(ns.stats||{}).packets_captured||0)+
      metric('Critical Alerts',crits,crits>0?'#ef4444':null);

    // Dark web
    const ds=await fetch('/api/v5/darkweb/stats').then(r=>r.json()).catch(()=>({}));
    document.getElementById('xDw').innerHTML=
      metric('Total Findings',ds.total_findings||0)+
      metric('Critical',ds.critical||0,ds.critical>0?'#ef4444':null)+
      metric('Cred Leaks',ds.credential_leaks||0,ds.credential_leaks>0?'#f97316':null);

    // SOAR
    const ss=await fetch('/api/v5/soar/stats').then(r=>r.json()).catch(()=>({}));
    document.getElementById('xSoar').innerHTML=
      metric('Active Rules',(ss.rules_enabled||0)+'/'+(ss.rules_total||0))+
      metric('Incidents',ss.total_incidents||0)+
      metric('Open Tickets',ss.open_tickets||0,ss.open_tickets>0?'#f97316':null);

    // CVEs
    const cs=await fetch('/api/v5/epss/top?limit=4').then(r=>r.json()).catch(()=>({cves:[]}));
    document.getElementById('xCve').innerHTML=(cs.cves||[]).map(c=>
      `<div class="exec-row"><span class="v5-cve-id">${c.cve_id}</span><span class="sev-pill sev-${c.priority}">${c.priority}</span></div>`
    ).join('')||metric('Status','No data');

    // Actors
    const as=await fetch('/api/v5/actors/stats').then(r=>r.json()).catch(()=>({}));
    document.getElementById('xActors').innerHTML=
      metric('Tracked',as.total_actors||0)+
      metric('CRITICAL',(as.by_risk||{}).CRITICAL||0,'#ef4444')+
      metric('HIGH',(as.by_risk||{}).HIGH||0,'#f97316');

    // Overall risk
    const totalCrit = crits + (ds.critical||0) + (ss.critical_count||0);
    const lvl = totalCrit>=5?'CRITICAL':totalCrit>=2?'HIGH':totalCrit>=1?'MEDIUM':'LOW';
    const score = totalCrit>=5?92:totalCrit>=2?71:totalCrit>=1?45:12;
    const col = riskCol[lvl];
    document.getElementById('riskScore').textContent=score;
    document.getElementById('riskScore').style.color=col;
    document.getElementById('riskLvl').textContent=lvl;
    document.getElementById('riskLvl').style.color=col;
    document.getElementById('riskRing').style.borderColor=col;
    document.getElementById('updatedAt').textContent=new Date().toLocaleTimeString();
  }catch(e){}
}
loadExec();
setInterval(loadExec,30000);
</script>
""")

