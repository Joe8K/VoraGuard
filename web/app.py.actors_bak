@app.route("/identity")
def identity_page():
    return page_wrap("Identity Exposure", "identity", V5_CSS + """
<div class="v5-hero" style="background:linear-gradient(135deg,#0c1222,#0d1520)">
  <div class="v5-hero-icon">🔐</div>
  <div>
    <div class="v5-hero-title">Identity Exposure Management</div>
    <div class="v5-hero-sub">Microsoft Entra · Google Workspace · Okta · Risky user detection · Auto-remediation</div>
  </div>
  <button class="v5-btn" onclick="scanAll()">🔍 Scan All Providers</button>
</div>
<div class="v5-content">
  <div class="v5-panel" id="entraCard">
    <div class="v5-ph">🏢 Microsoft Entra <span id="entraStatus" style="font-size:11px;margin-left:auto;color:#64748b">Not configured</span></div>
    <div class="v5-form">
      <div style="font-size:12px;color:#94a3b8">Set AZURE_TENANT_ID, AZURE_CLIENT_ID, AZURE_CLIENT_SECRET in ~/voraguard/.env</div>
      <button class="v5-btn" onclick="scanProvider('entra')">Scan Entra</button>
    </div>
    <div id="entraResult"></div>
  </div>
  <div class="v5-panel">
    <div class="v5-ph">🌐 Google Workspace <span id="gworkStatus" style="font-size:11px;margin-left:auto;color:#64748b">Not configured</span></div>
    <div class="v5-form">
      <div style="font-size:12px;color:#94a3b8">Set GOOGLE_WORKSPACE_DOMAIN, GOOGLE_WORKSPACE_ADMIN in ~/voraguard/.env</div>
      <button class="v5-btn" onclick="scanProvider('google')">Scan Workspace</button>
    </div>
    <div id="googleResult"></div>
  </div>
  <div class="v5-panel">
    <div class="v5-ph">🔑 Okta <span id="oktaStatus" style="font-size:11px;margin-left:auto;color:#64748b">Not configured</span></div>
    <div class="v5-form">
      <div style="font-size:12px;color:#94a3b8">Set OKTA_DOMAIN, OKTA_API_TOKEN in ~/voraguard/.env</div>
      <button class="v5-btn" onclick="scanProvider('okta')">Scan Okta</button>
    </div>
    <div id="oktaResult"></div>
  </div>
  <div class="v5-panel v5-panel-full">
    <div class="v5-ph">⚠️ All Findings <button class="v5-btn-ghost v5-btn-sm" onclick="loadIdentityFindings()">↻</button></div>
    <div id="identityFindings"><div class="v5-loading">Loading...</div></div>
  </div>
</div>
<script>
async function checkStatus(){
  try{
    const d=await fetch('/api/v5/identity/status').then(r=>r.json());
    const p=d.providers||{};
    if(p.entra&&p.entra.configured) document.getElementById('entraStatus').innerHTML='<span style="color:#22c55e">✓ Configured</span>';
    if(p.google&&p.google.configured) document.getElementById('gworkStatus').innerHTML='<span style="color:#22c55e">✓ Configured</span>';
    if(p.okta&&p.okta.configured) document.getElementById('oktaStatus').innerHTML='<span style="color:#22c55e">✓ Configured</span>';
  }catch(e){}
}
async function scanProvider(provider){
  const el=document.getElementById(provider+'Result')||(provider==='google'?document.getElementById('googleResult'):null);
  if(el) el.innerHTML='<div class="v5-loading">Scanning...</div>';
  try{
    const d=await fetch('/api/v5/identity/scan',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({provider})}).then(r=>r.json());
    const f=d.findings||[];
    if(el) el.innerHTML=f.length?f.map(x=>`<div class="v5-card sev-bd-${x.severity||'HIGH'}" style="margin-top:8px">
      <div class="v5-card-hdr"><span class="sev-pill sev-${x.severity||'HIGH'}">${x.severity||'HIGH'}</span><span class="v5-card-title">${x.title||''}</span></div>
      <div class="v5-card-body">${x.description||x.summary||''}</div>
    </div>`).join(''):'<div class="v5-ok">✓ No issues found</div>';
    loadIdentityFindings();
  }catch(e){if(el) el.innerHTML='<div class="v5-error">'+e.message+'</div>';}
}
async function scanAll(){['entra','google','okta'].forEach(scanProvider);}
async function loadIdentityFindings(){
  try{
    const d=await fetch('/api/v5/identity/findings').then(r=>r.json());
    const el=document.getElementById('identityFindings');
    const f=d.findings||[];
    if(!f.length){el.innerHTML='<div class="v5-empty">No findings yet. Configure providers and run a scan.</div>';return;}
    el.innerHTML=`<table class="v5-table"><thead><tr><th>Severity</th><th>Provider</th><th>User</th><th>Issue</th></tr></thead><tbody>
      ${f.map(x=>`<tr>
        <td><span class="sev-pill sev-${x.severity||'HIGH'}">${x.severity||'HIGH'}</span></td>
        <td style="color:#94a3b8">${x.provider||''}</td>
        <td>${(x.user||{}).email||(x.user||{}).name||x.user_email||''}</td>
        <td>${x.title||x.description||''}</td>
      </tr>`).join('')}
    </tbody></table>`;
  }catch(e){document.getElementById('identityFindings').innerHTML='<div class="v5-error">'+e.message+'</div>';}
}
checkStatus(); loadIdentityFindings();
</script>
""")

@app.route("/api/v5/identity/status")
def api_v5_id_status():
    if not _im: return jsonify({"providers":{},"error":"identity_manager not installed"})
    try:
        import os
        providers = {
            "entra":  {"configured": bool(os.environ.get("AZURE_TENANT_ID"))},
            "google": {"configured": bool(os.environ.get("GOOGLE_WORKSPACE_DOMAIN"))},
            "okta":   {"configured": bool(os.environ.get("OKTA_DOMAIN"))},
        }
        return jsonify({"providers": providers})
    except Exception as e:
        return jsonify({"providers":{},"error":str(e)})

@app.route("/api/v5/identity/scan", methods=["POST"])
def api_v5_id_scan():
    if not _im: return jsonify({"findings":[],"error":"identity_manager not installed"})
    try:
        provider = (request.json or {}).get("provider","all")
        if provider == "entra":
            findings = _im.scan_entra()
        elif provider == "google":
            findings = _im.scan_google_workspace()
        elif provider == "okta":
            findings = _im.scan_okta()
        else:
            findings = _im.scan_all_identity()
        if isinstance(findings, dict):
            findings = findings.get("findings", [])
        return jsonify({"findings": findings or []})
    except Exception as e:
        return jsonify({"findings":[],"error":str(e)})

@app.route("/api/v5/identity/findings")
def api_v5_id_findings():
    if not _im: return jsonify({"findings":[]})
    try:
        cached = _im.get_cached_results()
        findings = []
        if isinstance(cached, dict):
            for v in cached.values():
                if isinstance(v, list): findings.extend(v)
                elif isinstance(v, dict): findings.extend(v.get("findings",[]))
        elif isinstance(cached, list):
            findings = cached
        return jsonify({"findings": findings})
    except Exception as e:
        return jsonify({"findings":[],"error":str(e)})

