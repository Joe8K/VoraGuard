"""
VoraGuard HTML Report Generator v2 - Shows all 12 advanced modules
"""
import os
from pathlib import Path

def _badge(level):
    colors = {"CRITICAL":"bg-red-900/60 text-red-300","HIGH":"bg-orange-900/60 text-orange-300",
              "MEDIUM":"bg-yellow-900/60 text-yellow-300","LOW":"bg-green-900/60 text-green-300",
              "CLEAN":"bg-green-900/60 text-green-300","IMPROVED":"bg-blue-900/60 text-blue-300",
              "NONE":"bg-slate-700 text-slate-400","BREACHED":"bg-red-900/60 text-red-300",
              "ELEVATED":"bg-orange-900/60 text-orange-300"}
    cls = colors.get(level.upper() if level else "", "bg-slate-700 text-slate-400")
    return f'<span class="px-2 py-0.5 rounded text-xs font-bold {cls}">{level}</span>'

def generate_html_report(scan_result: dict, output_dir: str) -> str:
    import json
    d = scan_result
    domain = d.get("domain","Unknown")
    risk = d.get("risk",{})
    score = risk.get("score",0)
    risk_level = risk.get("risk_level","UNKNOWN")
    risk_color = risk.get("risk_color","#94a3b8")
    scan_id = d.get("scan_id","")
    duration = d.get("duration_seconds",0)
    scan_time = (d.get("completed_at","") or "")[:19].replace("T"," ")

    nmap=d.get("nmap",{}); dnstwist=d.get("dnstwist",{}); harvester=d.get("harvester",{})
    ip_scan=d.get("ip_scan",{}); scan_mode=d.get("scan_mode","domain")
    vt=d.get("vt_domain",{}); dns=d.get("dns_health",{}); ssl=d.get("ssl_info",{})
    def _sd(key, fallback=None):
        v = d.get(key, fallback if fallback is not None else {})
        return v if isinstance(v, dict) else (fallback if fallback is not None else {})
    vuln=_sd("vuln_analysis"); owasp=_sd("owasp"); grc=_sd("grc_report")
    delta=_sd("attack_surface_change"); biz=_sd("business_impact")
    reg=_sd("regulatory_breach"); sc=_sd("supply_chain")
    honey=_sd("honey_trap"); roi=_sd("attacker_roi")
    actors=_sd("threat_actors"); dw=_sd("darkweb"); sim=_sd("threat_sim")

    open_ports=nmap.get("open_ports",[]); typosquats=dnstwist.get("typosquats",[])[:15]
    emails=harvester.get("emails",[])[:15]; hosts=harvester.get("hosts",[])[:15]
    findings=risk.get("key_findings",[]); breakdown=risk.get("breakdown",{})

    HIGH_RISK={21,22,23,25,3306,3389,5900,6379,27017,9200,2375,1433}
    port_rows="".join(f'<tr class="border-b border-slate-700/50 hover:bg-slate-800/40"><td class="px-4 py-2.5 font-mono text-sm {'text-red-400' if p['port'] in HIGH_RISK else 'text-slate-300'}">{p['port']}/{p['protocol']}</td><td class="px-4 py-2.5 text-slate-300 text-sm">{p['service']}</td><td class="px-4 py-2.5 text-slate-500 text-xs">{str(p.get("version",""))[:40]}</td><td class="px-4 py-2.5">{_badge("CRITICAL" if p["port"] in HIGH_RISK else "LOW")}</td></tr>' for p in open_ports) or '<tr><td colspan="4" class="px-4 py-6 text-center text-slate-600 text-sm">No open ports</td></tr>'

    typo_rows="".join(f'<tr class="border-b border-slate-700/50"><td class="px-4 py-2.5 font-mono text-sm text-orange-300">{t.get("domain","")}</td><td class="px-4 py-2.5 text-slate-500 text-xs">{t.get("fuzzer","")}</td><td class="px-4 py-2.5 font-mono text-slate-500 text-xs">{t.get("dns_a","")}</td><td class="px-4 py-2.5">{_badge("HIGH")}</td></tr>' for t in typosquats) or '<tr><td colspan="4" class="px-4 py-6 text-center text-slate-600">None</td></tr>'

    bd_html=""
    for key,label in [("port_exposure","Port Exposure"),("vt_reputation","VT Reputation"),("typosquatting","Typosquatting"),("dns_health","DNS Health"),("ssl_tls","SSL/TLS")]:
        b=breakdown.get(key,{}); ded=b.get("deduction",0); mx=b.get("max",0)
        pct=int((ded/mx)*100) if mx else 0
        col="bg-green-500" if pct==0 else "bg-yellow-500" if pct<50 else "bg-red-500"
        bd_html+=f'<div class="mb-3"><div class="flex justify-between text-xs mb-1"><span class="text-slate-400">{label}</span><span class="text-slate-600">{ded}/{mx}</span></div><div class="h-1.5 bg-slate-700 rounded-full overflow-hidden"><div class="{col} h-full rounded-full" style="width:{pct}%"></div></div></div>'

    # Vuln findings
    vf_html=""
    for f in vuln.get("findings",[]):
        cves=" ".join(f'<span class="mono text-xs bg-slate-800 px-2 py-0.5 rounded border border-slate-600 text-slate-300">{c["cve"]} <span class="text-red-400">CVSS {c["cvss"]}</span></span>' for c in f.get("cves",[])[:3])
        vf_html+=f'<div class="border border-slate-700 rounded-xl p-4 mb-3"><div class="flex justify-between mb-2"><span class="font-bold mono text-sm">{f["port"]}/{f["service"]}</span>{_badge(f.get("severity","LOW"))}</div><div class="flex flex-wrap gap-1 mb-2">{cves}</div><p class="text-xs text-blue-400">{f.get("remediation","")}</p></div>'

    # OWASP
    ow_html=""
    for item in owasp.get("findings",[]):
        ev="".join(f'<li class="text-slate-400 text-xs">• {e}</li>' for e in item.get("evidence",[]))
        ow_html+=f'<div class="border border-slate-700 rounded-xl p-4 mb-3"><div class="flex justify-between mb-1"><span><span class="text-blue-400 mono text-xs">{item["id"]}</span> <span class="text-white font-semibold text-sm">{item["name"]}</span></span>{_badge(item.get("severity","MEDIUM"))}</div><p class="text-slate-400 text-xs mb-2">{item.get("description","")}</p><ul>{ev}</ul><p class="text-xs text-blue-400 mt-2">↳ {item.get("remediation","")}</p></div>'

    # GRC
    kri_html="".join(f'<div class="flex items-center justify-between py-2 border-b border-slate-700/50"><span class="text-slate-300 text-sm">{k["indicator"]}</span><div class="flex gap-2 items-center"><span class="text-slate-500 text-xs">{k["value"]}</span>{_badge(k["status"])}</div></div>' for k in grc.get("key_risk_indicators",[]))
    act_html="".join(f'<div class="flex items-start gap-3 py-2 border-b border-slate-700/50"><span class="px-2 py-0.5 text-xs font-bold rounded mono {'bg-red-900/60 text-red-300' if a['priority']=='P1' else 'bg-yellow-900/60 text-yellow-300' if a['priority']=='P2' else 'bg-blue-900/60 text-blue-300'}">{a["priority"]}</span><div><p class="text-slate-300 text-sm">{a["action"]}</p><p class="text-slate-600 text-xs">{a.get("owner","")}</p></div></div>' for a in grc.get("priority_actions",[]))

    # Threat chains
    ch_html=""
    for c in sim.get("attack_chains",[]):
        steps="".join(f'<div class="flex gap-3 py-1.5"><div class="w-2 h-2 rounded-full bg-blue-500 mt-1.5 shrink-0"></div><div><span class="text-xs text-blue-400 mono">{s["tactic"]}</span><p class="text-slate-300 text-xs">{s["desc"]}</p></div></div>' for s in c.get("steps",[]))
        ch_html+=f'<div class="border border-slate-700 rounded-xl p-4 mb-4"><div class="flex justify-between mb-2"><div><span class="text-slate-500 mono text-xs">{c["chain_id"]}</span><h4 class="text-white font-bold">{c["name"]}</h4></div>{_badge(c.get("likelihood","HIGH"))}</div><div class="grid grid-cols-3 gap-2 mb-3 text-xs"><div class="bg-slate-800 rounded p-2"><div class="text-slate-500 mb-1">Entry</div><div class="text-slate-300">{c.get("entry_point","")}</div></div><div class="bg-slate-800 rounded p-2"><div class="text-slate-500 mb-1">Time</div><div class="text-slate-300">{c.get("estimated_time_to_exploit","")}</div></div><div class="bg-slate-800 rounded p-2"><div class="text-slate-500 mb-1">Impact</div><div class="text-red-400 font-bold">{c.get("blast_radius","")}</div></div></div>{steps}</div>'

    # Actors
    ac_html=""
    for a in actors.get("actors",[]):
        ttps=" ".join(f'<span class="bg-slate-800 text-slate-400 text-xs px-2 py-0.5 rounded mono">{t}</span>' for t in a.get("matched_ttps",[])[:3])
        ac_html+=f'<div class="border border-slate-700 rounded-xl p-4 mb-3"><div class="flex justify-between mb-1"><span class="text-white font-bold">{a["group"]}</span><span class="text-yellow-400 text-sm font-bold mono">{a["correlation_score"]}%</span></div><p class="text-slate-500 text-xs mb-2">{a["nation_state"]} — {a["motivation"]}</p><div class="flex flex-wrap gap-1 mb-2">{ttps}</div><a href="{a["mitre_url"]}" class="text-blue-400 text-xs" target="_blank">→ MITRE ATT&CK</a></div>'

    # Regulatory
    rg_html="".join(f'<div class="border border-slate-700 rounded-xl p-4 mb-3"><div class="flex justify-between mb-1"><span class="text-white font-bold text-sm">{fw["framework"]}</span>{_badge(fw.get("risk","HIGH"))}</div><p class="text-slate-500 text-xs mono mb-2">{fw["article"]}</p><p class="text-slate-400 text-xs mb-1">{fw["violation_description"]}</p><p class="text-red-400 text-xs font-semibold">Fine: {fw["potential_fine"]}</p></div>' for fw in reg.get("findings",[])) or '<p class="text-green-400 text-sm">No regulatory breaches predicted.</p>'

    # Supply chain
    sq_html="".join(f'<div class="flex justify-between py-3 border-b border-slate-700/50"><div><div class="text-white font-semibold text-sm">{c["technology"]}</div><p class="text-slate-400 text-xs">{c["note"]}</p></div>{_badge(c["risk"])}</div>' for c in sc.get("components",[])) or '<p class="text-slate-500 text-sm">None detected.</p>'

    # Business impact
    bi_html=""
    for imp in biz.get("impact_findings",[]):
        bi_html+=f'<div class="border border-slate-700 rounded-xl p-4 mb-3"><div class="font-semibold text-white mb-2">{imp["asset"]} <span class="text-slate-500 mono text-xs">:{imp["port"]}</span></div><div class="grid grid-cols-3 gap-2 text-xs text-center mb-2"><div class="bg-slate-800 rounded p-2"><div class="text-slate-500">Confidentiality</div><div class="font-bold text-red-400">{imp["confidentiality"]}</div></div><div class="bg-slate-800 rounded p-2"><div class="text-slate-500">Integrity</div><div class="font-bold text-red-400">{imp["integrity"]}</div></div><div class="bg-slate-800 rounded p-2"><div class="text-slate-500">Availability</div><div class="font-bold text-orange-400">{imp["availability"]}</div></div></div><p class="text-slate-400 text-xs italic">{imp["breach_scenario"]}</p></div>'
    fin=biz.get("financial_risk_estimate",{})
    if fin:
        bi_html+=f'<div class="bg-red-900/20 border border-red-800/40 rounded-xl p-4 mt-2"><div class="text-xs text-slate-500 mb-1">Estimated Financial Exposure</div><div class="text-2xl font-bold text-red-400">{fin.get("minimum","")} – {fin.get("maximum","")}</div><div class="text-xs text-slate-500 mt-1">{fin.get("basis","")}</div></div>'

    # Honey + ROI
    hc={"LIKELY HONEYPOT":"text-red-400","POSSIBLE HONEYPOT":"text-yellow-400"}.get(honey.get("verdict",""),"text-green-400")
    hn_html=f'<div class="flex items-center gap-4 mb-4"><div class="text-3xl font-extrabold mono {hc}">{honey.get("confidence_pct",0)}%</div><div><div class="text-white font-bold">{honey.get("verdict","")}</div></div></div>'+"".join(f'<p class="text-sm text-slate-400 mb-1">• {i}</p>' for i in honey.get("indicators",[]))+f'<div class="mt-3 bg-slate-800 rounded p-3 text-xs text-slate-400">{honey.get("recommendation","")}</div>'

    rc={"EXTREMELY HIGH":"text-red-400","HIGH":"text-orange-400","MEDIUM":"text-yellow-400"}.get(roi.get("roi_label","").split(" ")[0]+" "+roi.get("roi_label","").split(" ")[1] if roi.get("roi_label") and len(roi.get("roi_label","").split(" "))>1 else "","text-green-400")
    roi_total=roi.get("total_roi_score",0)
    rc2="text-red-400" if roi_total>=75 else "text-orange-400" if roi_total>=55 else "text-yellow-400" if roi_total>=35 else "text-green-400"
    roi_html=f'<div class="flex items-center gap-4 mb-4"><div class="text-4xl font-extrabold mono {rc2}">{roi_total}<span class="text-slate-600 text-lg">/100</span></div><div class="text-white font-bold text-sm">{roi.get("roi_label","").split("—")[0] if roi.get("roi_label") else ""}</div></div><div class="grid grid-cols-3 gap-3 text-xs text-center"><div class="bg-slate-800 rounded p-3"><div class="text-slate-500 mb-1">Ease</div><div class="text-xl font-bold text-orange-400">{roi.get("ease_score",0)}/40</div></div><div class="bg-slate-800 rounded p-3"><div class="text-slate-500 mb-1">Value</div><div class="text-xl font-bold text-yellow-400">{roi.get("value_score",0)}/35</div></div><div class="bg-slate-800 rounded p-3"><div class="text-slate-500 mb-1">Stealth</div><div class="text-xl font-bold text-red-400">{roi.get("stealth_score",0)}/25</div></div></div><p class="text-slate-500 text-xs mt-3">{roi.get("attacker_type","")}</p>'

    # Delta
    dr=delta.get("delta_risk","NONE")
    dc={"CRITICAL":"text-red-400","HIGH":"text-orange-400","MEDIUM":"text-yellow-400","IMPROVED":"text-green-400","NONE":"text-slate-400"}.get(dr,"text-slate-400")
    dt_html=f'<div class="{dc} font-bold text-base mb-3">{delta.get("message","")}</div><div class="grid grid-cols-3 gap-3 text-xs text-center"><div class="bg-red-900/20 border border-red-800/30 rounded p-3"><div class="text-slate-500 mb-1">New Ports</div><div class="text-xl font-bold text-red-400">{len(delta.get("new_ports",[]))}</div></div><div class="bg-green-900/20 border border-green-800/30 rounded p-3"><div class="text-slate-500 mb-1">Closed</div><div class="text-xl font-bold text-green-400">{len(delta.get("closed_ports",[]))}</div></div><div class="bg-slate-800 rounded p-3"><div class="text-slate-500 mb-1">Unchanged</div><div class="text-xl font-bold text-slate-400">{len(delta.get("unchanged_ports",[]))}</div></div></div>{"<p class='text-xs text-slate-500 mt-2 mono'>Baseline: "+delta.get('baseline_timestamp','')[:19]+"</p>" if delta.get('baseline_timestamp') else "<p class='text-xs text-slate-500 mt-2'>First scan — baseline saved.</p>"}'

    # Dark web
    dw_html="".join(f'<div class="border border-red-900/50 rounded-xl p-4 mb-3 bg-red-900/10"><div class="flex justify-between mb-1"><span class="text-red-300 font-bold text-sm">{f["type"]}</span><span class="text-slate-500 text-xs">{f.get("date","")}</span></div><p class="text-slate-400 text-xs">{f.get("description","")}</p></div>' for f in dw.get("breach_findings",[])) or '<p class="text-green-400 text-sm">✓ No breach indicators in public databases.</p>'
    dw_html+=f'<p class="text-slate-600 text-xs mt-2">{dw.get("note","")}</p>'

    # VT + DNS + SSL
    vtr=vt.get("risk_level","unknown"); vtc={"high":"text-red-400","medium":"text-yellow-400","clean":"text-green-400"}.get(vtr,"text-slate-400")
    if vt.get("available"):
        import datetime as _dt
        vt_cats = vt.get("categories",[])
        vt_cat_html = "".join(f'<span class="bg-slate-700 text-slate-300 text-xs px-2 py-0.5 rounded">{c}</span>' for c in vt_cats[:8]) if vt_cats else '<span class="text-slate-600 text-xs">No categories detected</span>'
        vt_rep = vt.get("reputation_score",0)
        vt_rep_c = "text-green-400" if vt_rep >= 0 else "text-red-400"
        vt_rep_sign = "+" if vt_rep >= 0 else ""
        vt_date_raw = vt.get("last_analysis_date","")
        try:
            vt_date = _dt.datetime.fromtimestamp(int(vt_date_raw)).strftime("%Y-%m-%d %H:%M UTC") if str(vt_date_raw).isdigit() else str(vt_date_raw)
        except:
            vt_date = str(vt_date_raw) or "Unknown"
        vt_mal  = vt.get("malicious",0)
        vt_sus  = vt.get("suspicious",0)
        vt_harm = vt.get("harmless",0)
        vt_tot  = vt.get("total_engines",0)
        vt_html = (
            f'<div class="bg-slate-800/80 rounded-xl p-4 mb-3 flex items-center justify-between">' +
            f'<div><div class="text-xs text-slate-500 mb-1">Overall Verdict</div><div class="text-2xl font-extrabold mono {vtc}">{vtr.upper()}</div></div>' +
            f'<div class="text-right"><div class="text-xs text-slate-500 mb-1">Reputation Score</div><div class="text-2xl font-bold {vt_rep_c}">{vt_rep_sign}{vt_rep}</div></div></div>' +
            f'<div class="grid grid-cols-4 gap-2 mb-3">' +
            f'<div class="bg-slate-800 rounded-lg p-3 text-center"><div class="text-xs text-slate-500 mb-1">Malicious</div><div class="text-xl font-bold text-red-400">{vt_mal}</div></div>' +
            f'<div class="bg-slate-800 rounded-lg p-3 text-center"><div class="text-xs text-slate-500 mb-1">Suspicious</div><div class="text-xl font-bold text-yellow-400">{vt_sus}</div></div>' +
            f'<div class="bg-slate-800 rounded-lg p-3 text-center"><div class="text-xs text-slate-500 mb-1">Harmless</div><div class="text-xl font-bold text-green-400">{vt_harm}</div></div>' +
            f'<div class="bg-slate-800 rounded-lg p-3 text-center"><div class="text-xs text-slate-500 mb-1">Engines</div><div class="text-xl font-bold text-slate-300">{vt_tot}</div></div></div>' +
            f'<div class="bg-slate-800 rounded-lg p-3 mb-3"><div class="text-xs text-slate-500 mb-2">Categories</div><div class="flex flex-wrap gap-1">{vt_cat_html}</div></div>' +
            f'<div class="bg-slate-800 rounded-lg p-3"><div class="text-xs text-slate-500 mb-1">Last Analysed</div><div class="text-sm text-slate-300 mono">{vt_date}</div></div>'
        )
    else:
        vt_html = f'<div class="bg-yellow-900/20 border border-yellow-800/40 rounded-xl p-4"><p class="text-yellow-400 font-bold mb-1">⚠ VT Unavailable</p><p class="text-slate-400 text-xs">{vt.get("reason","No API key")}</p></div>'

    spf=dns.get("spf",{}).get("present",False); dm=dns.get("dmarc",{}).get("present",False)
    dns_html=f'<div class="grid grid-cols-2 gap-3 mb-3"><div class="bg-slate-800 rounded p-3 flex items-center gap-2"><span>{"✅" if spf else "❌"}</span><div><div class="text-sm font-semibold {"text-green-400" if spf else "text-red-400"}">SPF</div><div class="text-xs text-slate-500">{"OK" if spf else "Missing"}</div></div></div><div class="bg-slate-800 rounded p-3 flex items-center gap-2"><span>{"✅" if dm else "❌"}</span><div><div class="text-sm font-semibold {"text-green-400" if dm else "text-red-400"}">DMARC</div><div class="text-xs text-slate-500">{"OK" if dm else "Missing"}</div></div></div></div><div class="bg-slate-800 rounded p-2 text-xs mono text-slate-400">IPs: {", ".join(dns.get("ip_addresses",[])) or "N/A"}</div>'

    sv=ssl.get("valid",False)
    ssl_html=f'<div class="grid grid-cols-2 gap-3"><div class="bg-slate-800 rounded p-3"><div class="text-xs text-slate-500 mb-1">Status</div><div class="font-bold {"text-green-400" if sv else "text-red-400"}">{"✅ Valid" if sv else "❌ Invalid"}</div></div><div class="bg-slate-800 rounded p-3"><div class="text-xs text-slate-500 mb-1">Expires</div><div class="font-bold text-slate-300">{f'{ssl.get("expires_in_days")} days' if ssl.get("expires_in_days") is not None else "N/A"}</div></div><div class="bg-slate-800 rounded p-3"><div class="text-xs text-slate-500 mb-1">Issuer</div><div class="text-sm text-slate-300">{ssl.get("issuer","Unknown")}</div></div><div class="bg-slate-800 rounded p-3"><div class="text-xs text-slate-500 mb-1">Protocol</div><div class="text-sm text-slate-300">{ssl.get("protocol","Unknown")}</div></div></div>'+"".join(f'<p class="mt-2 text-xs text-red-400">⚠ {i}</p>' for i in ssl.get("issues",[]))

    ei="".join(f'<li class="mono text-xs text-slate-300 py-1 border-b border-slate-700/30">{e}</li>' for e in emails) or '<li class="text-slate-600 text-xs py-2">None</li>'
    hi="".join(f'<li class="mono text-xs text-slate-300 py-1 border-b border-slate-700/30">{h}</li>' for h in hosts)  or '<li class="text-slate-600 text-xs py-2">None</li>'
    fi="".join(f'<div class="flex items-start gap-2 py-2 border-b border-slate-700/30"><span class="text-red-400 mt-0.5">▲</span><span class="text-slate-300 text-sm">{f}</span></div>' for f in findings) or '<p class="text-green-400 text-sm">✓ No critical findings</p>'

    def sb(l,v,c="text-white"): return f'<div class="bg-slate-800/80 rounded-xl p-4 text-center"><div class="text-2xl font-extrabold mono {c}">{v}</div><div class="text-xs text-slate-500 mt-1">{l}</div></div>'
    stats="".join([sb("Open Ports",len(open_ports),"text-orange-400" if open_ports else "text-green-400"),sb("CVEs",vuln.get("total_findings",0),"text-red-400" if vuln.get("critical",0)>0 else "text-yellow-400"),sb("Typosquats",dnstwist.get("registered_count",0),"text-orange-400"),sb("OWASP",owasp.get("triggered_count",0),"text-yellow-400"),sb("Attack Chains",sim.get("total_chains",0),"text-red-400"),sb("Regulations",reg.get("frameworks_at_risk",0),"text-red-400"),sb("ROI Score",f'{roi.get("total_roi_score",0)}/100',"text-orange-400"),sb("Threat Actors",actors.get("matched_actor_count",0),"text-yellow-400")])

    S = "section-label"

    # ── IP Intelligence HTML (4 APIs unified) ──────────────────────────────
    ip_results = ip_scan.get("ip_results", [])
    ip_overall_score = ip_scan.get("overall_score", 0)
    ip_overall_threat = ip_scan.get("overall_threat", "UNKNOWN")
    ip_threat_c = {"CRITICAL":"text-red-400","HIGH":"text-orange-400","MEDIUM":"text-yellow-400","LOW":"text-green-400","CLEAN":"text-green-400"}.get(ip_overall_threat,"text-slate-400")
    sources_active = ip_scan.get("sources_active", [])
    total_cves_ip = ip_scan.get("total_cves", 0)
    ip_key_findings = ip_scan.get("key_findings", [])

    # Source badge builder
    def _src_badge(name, active_sources):
        on = name in active_sources
        cls = "bg-green-900/60 text-green-300 border border-green-700/40" if on else "bg-slate-800 text-slate-500 border border-slate-700"
        return f'<span class="px-2 py-1 rounded text-xs font-bold {cls}">{"✓" if on else "–"} {name}</span>'

    ip_sources_html = "".join([_src_badge(s, sources_active) for s in ["AbuseIPDB","Shodan","IPQualityScore","CriminalIP"]])

    ip_cards_html = ""
    for ipr in ip_results[:3]:
        ip_addr = ipr.get("ip","")
        uthreat = ipr.get("threat_level","UNKNOWN")
        uthreat_c = {"CRITICAL":"text-red-400","HIGH":"text-orange-400","MEDIUM":"text-yellow-400","LOW":"text-green-400","CLEAN":"text-green-400"}.get(uthreat,"text-slate-400")
        uscore  = ipr.get("unified_score",0)
        src_scores = ipr.get("source_scores",{})
        country = ipr.get("country","")
        org     = ipr.get("org","") or ipr.get("isp","")
        cves_ip = ipr.get("cves",[])
        ports_ip= ipr.get("open_ports",[])
        flags = []
        if ipr.get("is_tor"):     flags.append('<span class="bg-red-900/60 text-red-300 text-xs px-2 py-0.5 rounded font-bold">TOR</span>')
        if ipr.get("is_vpn"):     flags.append('<span class="bg-orange-900/60 text-orange-300 text-xs px-2 py-0.5 rounded font-bold">VPN</span>')
        if ipr.get("is_proxy"):   flags.append('<span class="bg-yellow-900/60 text-yellow-300 text-xs px-2 py-0.5 rounded font-bold">PROXY</span>')
        if ipr.get("is_bot"):     flags.append('<span class="bg-red-900/60 text-red-300 text-xs px-2 py-0.5 rounded font-bold">BOT</span>')
        if ipr.get("is_scanner"): flags.append('<span class="bg-purple-900/60 text-purple-300 text-xs px-2 py-0.5 rounded font-bold">SCANNER</span>')
        flags_html = " ".join(flags) or '<span class="text-slate-600 text-xs">No flags</span>'

        # Source score bars
        score_bars = ""
        for src, src_score in src_scores.items():
            bar_c = "bg-red-500" if src_score>=80 else "bg-orange-500" if src_score>=50 else "bg-yellow-500" if src_score>=20 else "bg-green-500"
            score_bars += f'<div class="mb-1"><div class="flex justify-between text-xs mb-0.5"><span class="text-slate-500">{src}</span><span class="text-slate-400">{src_score}</span></div><div class="h-1 bg-slate-700 rounded-full overflow-hidden"><div class="{bar_c} h-full rounded-full" style="width:{src_score}%"></div></div></div>'

        # CVE rows
        cve_rows_ip = "".join(
            f'<div class="flex items-center justify-between py-1 border-b border-slate-700/30"><span class="mono text-xs text-red-300">{c["cve"]}</span><span class="text-xs text-orange-400">CVSS {c.get("cvss",0)}</span></div>'
            for c in cves_ip[:5]
        ) or '<p class="text-green-400 text-xs">No CVEs detected</p>'

        # Port rows
        port_rows_ip = "".join(
            f'<span class="bg-slate-700 text-slate-300 mono text-xs px-2 py-0.5 rounded">{p["port"]}/{p.get("protocol","tcp")}</span>'
            for p in ports_ip[:8]
        ) or '<span class="text-slate-600 text-xs">None found</span>'

        # AbuseIPDB detail
        ab = ipr.get("abuseipdb",{})
        ab_score = ab.get("confidence_score",0)
        ab_c = "text-red-400" if ab_score>=80 else "text-orange-400" if ab_score>=50 else "text-yellow-400" if ab_score>0 else "text-green-400"
        ab_cats = ", ".join(ab.get("attack_categories",[])[:3]) or "None"
        ab_reports = ab.get("total_reports",0)

        # IPQS detail
        iq = ipr.get("ipqualityscore",{})
        iq_score = iq.get("fraud_score",0)
        iq_c = "text-red-400" if iq_score>=80 else "text-orange-400" if iq_score>=50 else "text-yellow-400" if iq_score>0 else "text-green-400"

        # CriminalIP detail
        ci = ipr.get("criminalip",{})
        ci_score = ci.get("attack_score",0)
        ci_c = "text-red-400" if ci_score>=80 else "text-orange-400" if ci_score>=50 else "text-yellow-400" if ci_score>0 else "text-green-400"

        ip_cards_html += f'''
        <div class="border border-slate-700 rounded-2xl p-5 mb-4">
          <!-- IP Header -->
          <div class="flex items-start justify-between mb-4">
            <div>
              <div class="flex items-center gap-3 mb-1">
                <span class="mono text-lg font-bold text-white">{ip_addr}</span>
                <span class="text-slate-500 text-sm">{country} · {org[:40]}</span>
              </div>
              <div class="flex flex-wrap gap-1">{flags_html}</div>
            </div>
            <div class="text-right">
              <div class="text-xs text-slate-500 mb-1">Unified Threat</div>
              <div class="text-2xl font-extrabold mono {uthreat_c}">{uthreat}</div>
              <div class="text-xs text-slate-600">{uscore}/100</div>
            </div>
          </div>
          <!-- Source Scores -->
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-4">
            <div class="bg-slate-800/60 rounded-xl p-4">
              <div class="text-xs text-slate-500 uppercase mb-3">Source Scores</div>
              {score_bars}
            </div>
            <div class="bg-slate-800/60 rounded-xl p-4">
              <div class="text-xs text-slate-500 uppercase mb-2">API Details</div>
              <div class="flex justify-between py-1 border-b border-slate-700/30">
                <span class="text-xs text-slate-400">AbuseIPDB Confidence</span>
                <span class="text-xs font-bold {ab_c}">{ab_score}%</span>
              </div>
              <div class="flex justify-between py-1 border-b border-slate-700/30">
                <span class="text-xs text-slate-400">Attack Categories</span>
                <span class="text-xs text-slate-300">{ab_cats}</span>
              </div>
              <div class="flex justify-between py-1 border-b border-slate-700/30">
                <span class="text-xs text-slate-400">Community Reports</span>
                <span class="text-xs text-slate-300">{ab_reports:,}</span>
              </div>
              <div class="flex justify-between py-1 border-b border-slate-700/30">
                <span class="text-xs text-slate-400">IPQS Fraud Score</span>
                <span class="text-xs font-bold {iq_c}">{iq_score}%</span>
              </div>
              <div class="flex justify-between py-1">
                <span class="text-xs text-slate-400">CriminalIP Attack Score</span>
                <span class="text-xs font-bold {ci_c}">{ci_score}</span>
              </div>
            </div>
          </div>
          <!-- Ports + CVEs -->
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
            <div class="bg-slate-800/60 rounded-xl p-4">
              <div class="text-xs text-slate-500 uppercase mb-2">Open Ports ({len(ports_ip)})</div>
              <div class="flex flex-wrap gap-1">{port_rows_ip}</div>
            </div>
            <div class="bg-slate-800/60 rounded-xl p-4">
              <div class="text-xs text-slate-500 uppercase mb-2">CVEs ({len(cves_ip)})</div>
              {cve_rows_ip}
            </div>
          </div>
        </div>
        '''

    ip_findings_html = "".join(
        f'<div class="flex items-start gap-2 py-2 border-b border-slate-700/30"><span class="text-orange-400 mt-0.5">▲</span><span class="text-slate-300 text-sm">{f}</span></div>'
        for f in ip_key_findings
    ) or '<p class="text-green-400 text-sm">✓ No malicious indicators found</p>'

    if ip_scan.get("success"):
        ip_intel_html = f'''
        <div class="mb-3 flex items-center justify-between">
          <div>
            <div class="flex items-center gap-3 mb-2">
              <span class="text-2xl font-extrabold mono {ip_threat_c}">{ip_overall_threat}</span>
              <span class="text-slate-500 text-sm">Unified Score: {ip_overall_score}/100</span>
              <span class="text-slate-500 text-sm">·</span>
              <span class="text-slate-400 text-sm">{total_cves_ip} CVEs · {ip_scan.get("total_reports",0):,} abuse reports</span>
            </div>
            <div class="flex flex-wrap gap-2">{ip_sources_html}</div>
          </div>
        </div>
        <div class="mb-4">{ip_findings_html}</div>
        {ip_cards_html}
        '''
    else:
        ip_intel_html = f'<p class="text-slate-500 text-sm">{ip_scan.get("error","IP scan not available")}</p>'

    html = f"""<!DOCTYPE html>
<html lang="en"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
<title>VoraGuard — {domain}</title>
<script src="https://cdn.tailwindcss.com"></script>
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>*{{font-family:'Syne',sans-serif}}.mono{{font-family:'Space Mono',monospace}}body{{background:#080d18}}.card{{background:rgba(15,23,42,.85);border:1px solid rgba(148,163,184,.1)}}.score-ring{{background:conic-gradient({risk_color} {score*3.6}deg,rgba(30,41,59,.8) 0deg);border-radius:50%}}.glow{{text-shadow:0 0 30px rgba(99,179,237,.4)}}.fade-in{{animation:fadeIn .5s ease-out forwards;opacity:0}}@keyframes fadeIn{{to{{opacity:1}}}}::-webkit-scrollbar{{width:5px}}::-webkit-scrollbar-track{{background:#0f172a}}::-webkit-scrollbar-thumb{{background:#334155;border-radius:3px}}.SL{{font-size:.65rem;letter-spacing:.15em;color:#475569;text-transform:uppercase;margin-bottom:1rem}}</style>
</head><body class="min-h-screen text-white">
<header class="border-b border-slate-800 bg-slate-900/60 backdrop-blur sticky top-0 z-50">
<div class="max-w-7xl mx-auto px-6 py-3 flex items-center justify-between">
<div class="flex items-center gap-3"><div class="w-7 h-7 rounded bg-blue-500/20 border border-blue-500/30 flex items-center justify-center"><svg class="w-3.5 h-3.5 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg></div>
<span class="font-bold tracking-widest mono text-sm">VORAGUARD</span><span class="text-slate-600 text-xs mono">v2.0</span></div>
<div class="text-xs text-slate-600 mono">{scan_time} · {duration:.0f}s · {scan_id}</div></div></header>
<main class="max-w-7xl mx-auto px-6 py-10">
<div class="text-center mb-10 fade-in"><p class="text-blue-400 mono text-xs uppercase tracking-widest mb-2">Full Threat Intelligence Report</p><h1 class="text-4xl font-extrabold glow mb-1">{domain}</h1></div>
<div class="grid grid-cols-1 lg:grid-cols-3 gap-5 mb-8 fade-in" style="animation-delay:.1s">
<div class="card rounded-2xl p-8 flex flex-col items-center justify-center">
<div class="relative w-36 h-36 mb-4"><div class="score-ring w-full h-full flex items-center justify-center"><div class="w-24 h-24 rounded-full bg-[#080d18] flex flex-col items-center justify-center"><span class="text-3xl font-extrabold" style="color:{risk_color}">{score}</span><span class="text-xs text-slate-600 mono">/100</span></div></div></div>
<div class="text-lg font-bold mono" style="color:{risk_color}">{risk_level} RISK</div>
<div class="text-xs text-slate-600 mt-1">{grc.get("appetite_status","")}</div></div>
<div class="card rounded-2xl p-5 col-span-2"><div class="SL">Risk Score Breakdown</div>{bd_html}</div></div>
<div class="grid grid-cols-4 md:grid-cols-8 gap-3 mb-8 fade-in" style="animation-delay:.15s">{stats}</div>
<div class="card rounded-2xl p-6 mb-5 fade-in" style="animation-delay:.2s"><div class="SL">⚡ Key Findings</div>{fi}</div>
<div class="card rounded-2xl p-6 mb-6 fade-in" style="animation-delay:.25s"><div class="SL">📋 GRC Executive Report</div>
<div class="grid grid-cols-1 lg:grid-cols-2 gap-6"><div><p class="text-slate-300 text-sm mb-4">{grc.get("executive_summary","")}</p><div class="SL mt-4">Key Risk Indicators</div>{kri_html or '<p class="text-green-400 text-sm">None</p>'}</div>
<div><div class="SL">Priority Actions</div>{act_html or '<p class="text-green-400 text-sm">None required</p>'}</div></div></div>
<div class="grid grid-cols-1 lg:grid-cols-2 gap-5 mb-5">
<div class="card rounded-2xl p-6 fade-in" style="animation-delay:.3s"><div class="SL">🔍 Open Ports ({len(open_ports)})</div><div class="overflow-auto max-h-72"><table class="w-full text-left text-sm"><thead><tr class="text-xs text-slate-600 uppercase border-b border-slate-700"><th class="px-4 py-2">Port</th><th class="px-4 py-2">Service</th><th class="px-4 py-2">Version</th><th class="px-4 py-2">Risk</th></tr></thead><tbody>{port_rows}</tbody></table></div></div>
<div class="card rounded-2xl p-6 fade-in" style="animation-delay:.35s"><div class="SL">🎭 Typosquatting ({dnstwist.get("registered_count",0)} registered)</div><div class="overflow-auto max-h-72"><table class="w-full text-left text-sm"><thead><tr class="text-xs text-slate-600 uppercase border-b border-slate-700"><th class="px-4 py-2">Domain</th><th class="px-4 py-2">Type</th><th class="px-4 py-2">IP</th><th class="px-4 py-2">Status</th></tr></thead><tbody>{typo_rows}</tbody></table></div></div></div>
<div class="card rounded-2xl p-6 mb-5 fade-in" style="animation-delay:.4s"><div class="flex justify-between items-center mb-4"><div class="SL mb-0">🛡 Vulnerability Analysis</div><div class="flex gap-2">{_badge("CRITICAL")}<span class="text-red-400 font-bold text-sm">{vuln.get("critical",0)}</span>{_badge("HIGH")}<span class="text-orange-400 font-bold text-sm">{vuln.get("high",0)}</span>{_badge("MEDIUM")}<span class="text-yellow-400 font-bold text-sm">{vuln.get("medium",0)}</span></div></div>{vf_html or '<p class="text-slate-500 text-sm">No ports to analyze.</p>'}</div>
<div class="card rounded-2xl p-6 mb-5 fade-in" style="animation-delay:.45s"><div class="SL">📋 OWASP Top 10 2021 — {owasp.get("triggered_count",0)} triggered</div>{ow_html}</div>
<div class="card rounded-2xl p-6 mb-5 fade-in" style="animation-delay:.5s"><div class="SL">⚔ Threat Simulation — {sim.get("total_chains",0)} attack chains</div><p class="text-slate-500 text-xs mb-4">{sim.get("summary","")}</p>{ch_html}</div>
<div class="grid grid-cols-1 lg:grid-cols-2 gap-5 mb-5">
<div class="card rounded-2xl p-6 fade-in" style="animation-delay:.55s"><div class="SL">🕵️ Threat Actor Correlation</div>{ac_html or '<p class="text-slate-500 text-sm">None correlated.</p>'}</div>
<div class="card rounded-2xl p-6 fade-in" style="animation-delay:.6s"><div class="SL">⚖ Regulatory Breach Prediction</div>{rg_html}</div></div>
<div class="card rounded-2xl p-6 mb-5 fade-in" style="animation-delay:.65s"><div class="SL">💼 Business Impact (CIA Triad)</div>{bi_html or '<p class="text-slate-500 text-sm">No high-impact assets exposed.</p>'}</div>
<div class="grid grid-cols-1 lg:grid-cols-2 gap-5 mb-5">
<div class="card rounded-2xl p-6 fade-in" style="animation-delay:.7s"><div class="SL">🔗 Supply Chain Map ({sc.get("components_detected",0)} detected)</div>{sq_html}</div>
<div class="card rounded-2xl p-6 fade-in" style="animation-delay:.75s"><div class="SL">📊 Attack Surface Change</div>{dt_html}</div></div>
<div class="grid grid-cols-1 lg:grid-cols-2 gap-5 mb-5">
<div class="card rounded-2xl p-6 fade-in" style="animation-delay:.8s"><div class="SL">💰 Attacker ROI Score</div>{roi_html}</div>
<div class="card rounded-2xl p-6 fade-in" style="animation-delay:.85s"><div class="SL">🍯 Honey-Trap Detection</div>{hn_html}</div></div>
<div class="card rounded-2xl p-6 mb-5 fade-in" style="animation-delay:.9s"><div class="SL">🌑 Dark Web Monitoring</div>{dw_html}</div>
<div class="card rounded-2xl p-6 mb-5 fade-in" style="animation-delay:.92s">
  <div class="SL">🔎 IP Intelligence — 4-Source Unified Report</div>
  <p class="text-slate-500 text-xs mb-4">AbuseIPDB · Shodan · IPQualityScore · CriminalIP — all data combined into one report</p>
  {ip_intel_html}
</div>
<div class="grid grid-cols-1 lg:grid-cols-3 gap-5 mb-8">
<div class="card rounded-2xl p-6 fade-in" style="animation-delay:.95s"><div class="SL">🦠 VirusTotal</div>{vt_html}</div>
<div class="card rounded-2xl p-6 fade-in" style="animation-delay:1s"><div class="SL">📡 DNS Health</div>{dns_html}</div>
<div class="card rounded-2xl p-6 fade-in" style="animation-delay:1.05s"><div class="SL">🔒 SSL/TLS</div>{ssl_html}</div></div>
<div class="card rounded-2xl p-6 mb-10 fade-in" style="animation-delay:1.1s"><div class="SL">🕵 OSINT</div><div class="grid grid-cols-2 gap-6"><div><div class="text-xs text-slate-500 uppercase mb-2">Emails ({len(emails)})</div><ul class="max-h-48 overflow-auto divide-y divide-slate-700/30">{ei}</ul></div><div><div class="text-xs text-slate-500 uppercase mb-2">Subdomains ({len(hosts)})</div><ul class="max-h-48 overflow-auto divide-y divide-slate-700/30">{hi}</ul></div></div></div>
</main>
<footer class="border-t border-slate-800 py-6 text-center text-xs text-slate-700 mono">VoraGuard Threat Intelligence Platform — Authorized use only</footer>
</body></html>"""

    from pathlib import Path
    rp = Path(output_dir) / "report.html"
    rp.parent.mkdir(parents=True, exist_ok=True)
    rp.write_text(html)
    return str(rp)
